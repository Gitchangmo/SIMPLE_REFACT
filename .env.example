# ============================================================
# 🔒 AI 지능형 냉장고 시스템 - 환경 변수 설정 파일 템플릿
# ============================================================
# 📌 사용법:
#   1. 이 파일을 복사하여 `.env` 파일로 저장
#   2. 실제 값으로 교체
#   3. `.env` 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# ====================
# 🔑 API Keys (외부 서비스)
# ====================

# OpenAI API Key (ChatGPT 챗봇 기능용)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# YouTube Data API Key (레시피 영상 검색용)
# 발급: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ====================
# 🔥 Firebase 설정
# ====================

# Firebase 서비스 계정 JSON 파일 경로 (절대 경로 또는 상대 경로)
# SIMPLE_AI용 (Vision 파이프라인)
FIREBASE_CRED_PATH_VISION=./JSON_FILE/simple.json

# server_test용 (FastAPI 백엔드)
FIREBASE_CRED_PATH_SERVER=./json_file/simple.json

# ====================
# 🌐 네트워크 설정 (ZeroMQ / 서버)
# ====================

# ZeroMQ 바인드 주소 (라즈베리파이 → PC)
# 형식: tcp://<IP>:<PORT> 또는 tcp://*:<PORT>
ZMQ_BIND_ADDRESS=tcp://*:5560
ZMQ_PORT=5560

# FastAPI 백엔드 서버 주소
FASTAPI_SERVER_HOST=192.168.200.130
FASTAPI_SERVER_PORT=8000
FASTAPI_SERVER_URL=http://192.168.200.130:8000

# ====================
# 🧠 AI 모델 경로
# ====================

# YOLO 모델 파일 경로
YOLO_MODEL_PATH=./YOLO_MODEL/final_v1.pt
# YOLO ONNX 모델 (경량화 후)
YOLO_ONNX_PATH=./YOLO_ONNX/final_v1.onnx

# LSTM 모델 파일 경로
LSTM_MODEL_PATH=./LSTM_MODEL/lstm_model_new_final_simple(0722)_v2.pth

# ====================
# 📷 이미지/카메라 설정
# ====================

# 입력 이미지 크기
IMG_WIDTH=1280
IMG_HEIGHT=720

# ROI (Region of Interest) 시작점
ROI_START=832

# LSTM 시퀀스 길이
SEQ_LEN=120

# ====================
# ⏰ 스케줄러 설정
# ====================

# 유통기한 알림 발송 시간 (cron 형식)
NOTIFY_HOUR=20
NOTIFY_MINUTE=13
NOTIFY_SECOND=10

# 타임존
TIMEZONE=Asia/Seoul

# ====================
# 🛠️ 개발/디버그 모드
# ====================

# 환경 설정 (development / staging / production)
ENVIRONMENT=development

# 디버그 모드 (True / False)
DEBUG=True

# 로깅 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
