<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LegendStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="TabDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#222</item>
        <item name="android:padding">6dp</item>
    </style>

    <style name="TagButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">40dp</item>
        <item name="strokeColor">#CCCCCC</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">#444444</item>
        <item name="android:paddingStart">5dp</item>
        <item name="android:paddingEnd">5dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:backgroundTint">#FFFFFF</item>
    </style>

    <style name="confirmButton" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="buttonStyle">@style/Widget.AppCompat.Button</item>
        <item name="colorPrimary">#06923E</item>
        <item name="colorPrimaryDark">#06923E</item>
        <item name="colorAccent">#06923E</item>
    </style>

    <style name="cancelButtonStyle" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="buttonStyle">@style/Widget.AppCompat.Button</item>
        <item name="android:textColor">#2E5130</item>
        <item name="android:backgroundTint">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="colorAccent">#06923E</item>
    </style>


</resources>
