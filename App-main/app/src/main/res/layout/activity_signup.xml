<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">


    <ImageButton
        android:id="@+id/back_IButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_margin="10dp"
        android:layout_marginTop="20dp"
        android:background="@null"
        android:contentDescription="뒤로가기 버튼"
        android:scaleType="centerInside"
        android:src="@drawable/back" />


    <TextView
        android:id="@+id/logo_Text"
        android:layout_width="wrap_content"
        android:layout_height="101dp"
        android:layout_marginBottom="8dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="70dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="SIMPLE"
        android:textColor="#2E5130"
        android:textSize="60sp"
        android:textStyle="bold" />


    <EditText
        android:id="@+id/name_EText"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_below="@id/logo_Text"
        android:layout_centerHorizontal="true"
        android:layout_gravity="center"
        android:layout_marginStart="16dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:hint="이름 입력"
        android:outlineAmbientShadowColor="#B0BEC5"
        android:outlineSpotShadowColor="#607D8B"
        android:paddingLeft="12dp"
        android:textSize="16sp" />

    <!-- 경고 메세지 -->
    <TextView
        android:id="@+id/name_warning_Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/name_EText"
        android:layout_alignParentStart="true"
        android:layout_marginStart="50dp"
        android:layout_marginTop="5dp"
        android:text="닉네임을 입력해주세요"
        android:textColor="#C3C3C3"
        android:textSize="14sp"
        android:visibility="visible" />

    <EditText
        android:id="@+id/email_EText"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_below="@id/name_warning_Text"
        android:layout_centerHorizontal="true"
        android:hint="이메일 입력"
        android:textSize="16sp"
        android:paddingLeft="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="15dp"
        android:outlineAmbientShadowColor="#B0BEC5"
        android:outlineSpotShadowColor="#607D8B"
        android:layout_gravity="center" />

    <!-- 경고 메세지 -->
    <TextView
        android:id="@+id/email_warning_Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/email_EText"
        android:layout_alignParentStart="true"
        android:layout_marginStart="50dp"
        android:layout_marginTop="5dp"
        android:text="아이디/비밀번호찾기 필수 항목입니다."
        android:textColor="#C3C3C3"
        android:textSize="14sp"
        android:visibility="visible" />




    <EditText
        android:id="@+id/password_EText"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_below="@+id/email_warning_Text"
        android:layout_centerHorizontal="true"
        android:hint="비밀번호 입력"
        android:textSize="16sp"
        android:paddingLeft="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="15dp"
        android:outlineAmbientShadowColor="#B0BEC5"
        android:outlineSpotShadowColor="#607D8B"
        android:layout_gravity="center" />


    <EditText
        android:id="@+id/password_retry_EText"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_below="@id/password_EText"
        android:layout_centerHorizontal="true"
        android:hint="비밀번호 확인"
        android:textSize="16sp"
        android:paddingLeft="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="15dp"
        android:outlineAmbientShadowColor="#B0BEC5"
        android:outlineSpotShadowColor="#607D8B"
        android:layout_gravity="center" />

    <!-- 경고 메세지 -->
    <TextView
        android:id="@+id/password_warning_Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/password_retry_EText"
        android:layout_alignParentStart="true"
        android:layout_marginStart="50dp"
        android:layout_marginTop="5dp"
        android:text="6자-20자 / 영문 대소문자, 숫자, 특수문자(._!) 조합"
        android:textColor="#C3C3C3"
        android:textSize="14sp"
        android:visibility="visible" />

    <Button
        android:id="@+id/complete_Button"
        android:layout_width="320dp"
        android:layout_height="55dp"
        android:layout_below="@id/password_warning_Text"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:backgroundTint="#2E5130"
        android:padding="10dp"
        android:radius="0dp"
        android:shape="rectangle"
        android:text="완료"
        android:textColor="@android:color/white"
        android:textSize="16sp" />
</RelativeLayout>
