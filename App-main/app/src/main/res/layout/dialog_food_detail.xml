<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/dialog_bg"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <!-- 사진 + 이름/카테고리 + 보관방식 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp"
            android:elevation="4dp"
            android:radius="12dp"
            android:padding="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical">

                <!-- 이미지 -->
                <ImageView
                    android:id="@+id/detail_image"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="15dp"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="16dp" />

                <!-- 이름과 카테고리 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/detail_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="음식 이름"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="카테고리"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
                <Spinner
                    android:id="@+id/storage_spinner"
                    android:background="@drawable/spinner_background"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginStart="5dp"
                    android:padding="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 구매일자 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="구매일자"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <EditText
                android:id="@+id/detail_added_date"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:focusable="false"
                android:textSize="14sp"
                android:hint="날짜 선택"
                android:background="@android:color/transparent"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 소비기한 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="소비기한"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <EditText
                android:id="@+id/detail_expiry_date"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:focusable="false"
                android:hint="날짜 선택"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 수량 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="   수량     "
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <Spinner
                android:id="@+id/detail_quantity_spinner"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:textSize="14sp"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="16dp">

            <!-- 폐기 & 삭제 버튼 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="start">

                <!-- 폐기 버튼 -->
                <Button
                    android:id="@+id/discard_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="폐기"
                    android:textColor="#2E5130"
                    android:textStyle="bold"
                    android:backgroundTint="@android:color/transparent"
                    android:layout_marginEnd="8dp" />

                <!-- 소비 버튼 -->
                <Button
                    android:id="@+id/consume_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="소비"
                    android:textColor="#2E5130"
                    android:textStyle="bold"
                    android:backgroundTint="@android:color/transparent"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 완료 버튼 -->
            <Button
                android:id="@+id/complete_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="1dp"
                android:layout_weight="1"
                android:background="@null"
                android:backgroundTint="#2E5130"
                android:elevation="0dp"
                android:outlineProvider="none"
                android:text="완료"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
