<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/diet_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@android:color/white">
    <!-- 빈 레이아웃이므로 아무 것도 넣지 않습니다 -->
    <!-- 🔼 상단 고정 버튼 영역 -->
    <include layout="@layout/view_top_buttons" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="16dp"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="55dp">
            <TextView
                android:id="@+id/text_cart_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginBottom="10dp"
                android:layout_marginLeft="12dp"
                android:text="장바구니에 구매 목록을 추가하세요!"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 재료추가 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_cart_list_button"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginEnd="3dp"
                android:backgroundTint="#E3E3E3"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="+ 재료추가"
                android:textColor="#8C8C8C"
                android:textSize="12sp"
                app:cornerRadius="24dp"
                />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cart_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@+id/text_cart_title"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_add_to_inventory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="재고에 바로 추가하기"
            android:backgroundTint="#2E5130"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

</FrameLayout>
