<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">


    <TextView
        android:id="@+id/logo_Text"
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:layout_marginBottom="8dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="160dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="SIMPLE"
        android:textColor="#2E5130"
        android:textSize="60sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sub_Text"
        android:layout_width="wrap_content"
        android:layout_height="25dp"
        android:layout_below="@id/logo_Text"
        android:layout_marginStart="50dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:lineSpacingExtra="0dp"
        android:text="음식 관리의 새로운 기준, 지금 시작하세요!"
        android:textColor="#2E5130"
        android:textSize="17sp" />

    <EditText
        android:id="@+id/email_EText"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_below="@id/sub_Text"
        android:layout_centerHorizontal="true"
        android:hint="이메일 입력"
        android:textSize="16sp"
        android:paddingLeft="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="50dp"
        android:outlineAmbientShadowColor="#B0BEC5"
        android:outlineSpotShadowColor="#607D8B"
        android:layout_gravity="center" />

    <EditText
        android:id="@+id/password_EText"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_below="@+id/email_EText"
        android:layout_centerHorizontal="true"
        android:hint="비밀번호 입력"
        android:inputType="textPassword"
        android:textSize="16sp"
        android:paddingLeft="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="15dp"
        android:outlineAmbientShadowColor="#B0BEC5"
        android:outlineSpotShadowColor="#607D8B" />


    <Button
        android:id="@+id/complete_Button"
        android:layout_width="320dp"
        android:layout_height="55dp"
        android:layout_below="@id/password_EText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:backgroundTint="#2E5130"
        android:padding="10dp"
        android:radius="0dp"
        android:shape="rectangle"
        android:text="로그인"
        android:textColor="@android:color/white"
        android:textSize="16sp" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/complete_Button"
        android:layout_centerHorizontal="true"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/find_email_Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/complete_Button"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="이메일 찾기"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/complete_Button"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:text="|   "
            android:textSize="16sp"></TextView>

        <TextView
            android:id="@+id/find_password_Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignRight="@id/find_email_Button"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="비밀번호 찾기"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/complete_Button"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:text="|   "
            android:textSize="16sp"></TextView>

        <TextView
            android:id="@+id/find_Signup_Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/complete_Button"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="회원가입"
            android:textSize="16sp" />

    </LinearLayout>

</RelativeLayout>