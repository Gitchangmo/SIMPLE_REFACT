<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 검색창 -->
    <SearchView
        android:id="@+id/food_search_view"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="8dp"
        android:queryHint="냉장고 속 재료를 찾아보세요!"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/add_ingredient_button" />

    <!-- 재료추가 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_ingredient_button"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="#E3E3E3"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="+ 재료추가"
        android:textColor="#8C8C8C"
        android:textSize="12sp"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 음식 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/food_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:paddingBottom="80dp"
        android:layout_marginStart="7dp"
        android:layout_marginEnd="7dp"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/food_search_view"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 도움말 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/help_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="20dp"
        android:background="@drawable/circle_button_bg"
        android:backgroundTint="@null"
        android:elevation="6dp"
        android:gravity="center"
        android:text="\?"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
