# ============================================================
#  AI 지능형 냉장고 시스템 - .gitignore
# ============================================================
#  Python + OpenCV + PyTorch + FastAPI + 딥러닝 프로젝트용
# ============================================================

# ====================
# 보안 관련 (최우선 제외)
# ====================

# 환경 변수 파일 (시크릿 포함)
.env
.env.local
.env.*.local
.env.production
.env.staging
*.env
.env

# Firebase/GCP 서비스 계정 키
JSON_FILE/
json_file/
**/service_account*.json
**/firebase*.json
**/google*.json
**/*credentials*.json
**/*secret*.json
**/simple.json

# Android Firebase 설정
**/google-services.json
**/*-firebase-adminsdk-*.json

# API 키 파일
*.key
*.pem
*.p12
*.pfx

# ====================
# Python 관련
# ====================

# 바이트코드
__pycache__/
*.py[cod]
*$py.class

# C 확장
*.so

# 배포/패키징
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# 가상환경
venv/
ENV/
env/
.venv/
.ENV/
env.bak/
venv.bak/
virtualenv/
.virtualenv/
simple_refact/

# pip
pip-log.txt
pip-delete-this-directory.txt

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

